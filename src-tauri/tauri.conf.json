{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillForge Academy",
  "version": "1.3.0",
  "identifier": "com.apexlearning.aplusacademy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillForge Academy",
        "width": 1440,
        "height": 920,
        "minWidth": 1060,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../src/content/certifications.json": "content/certifications.json",
      "../src/content/a-plus/domains.json": "content/a-plus/domains.json",
      "../src/content/a-plus/questions.json": "content/a-plus/questions.json",
      "../src/content/a-plus/flashcards.json": "content/a-plus/flashcards.json",
      "../src/content/a-plus/pbqs.json": "content/a-plus/pbqs.json"
    },
    "shortDescription": "Offline-first certification learning and exam-prep desktop app, starting with CompTIA A+.",
    "longDescription": "Offline-first certification learning and exam-prep desktop app, starting with CompTIA A+. A focused desktop learning environment with objective tracking, practice exams, spaced repetition, notes, bookmarks, and detailed analytics.",
    "category": "Education",
    "copyright": "Copyright 2026 ForgeWire Labs",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  }
}
